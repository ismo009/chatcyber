<?xml version="1.0" encoding="UTF-8"?>
<project xmlns="http://maven.apache.org/POM/4.0.0" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://maven.apache.org/POM/4.0.0 http://maven.apache.org/maven-v4_0_0.xsd">
  <modelVersion>4.0.0</modelVersion>
  <groupId>com.chatcyber</groupId>
  <artifactId>chatcyber</artifactId>
  <name>ChatCyber - Messagerie Sécurisée IBE</name>
  <version>1.0-SNAPSHOT</version>
  <description>Client mail sécurisé avec chiffrement à base d'identité (Boneh-Franklin IBE)</description>
  <build>
    <plugins>
      <plugin>
        <artifactId>maven-compiler-plugin</artifactId>
        <version>3.11.0</version>
        <configuration>
          <source>11</source>
          <target>11</target>
          <encoding>UTF-8</encoding>
        </configuration>
      </plugin>
      <plugin>
        <artifactId>maven-jar-plugin</artifactId>
        <version>3.3.0</version>
        <configuration>
          <archive>
            <manifest>
              <mainClass>com.chatcyber.App</mainClass>
            </manifest>
          </archive>
        </configuration>
      </plugin>
      <plugin>
        <artifactId>maven-shade-plugin</artifactId>
        <version>3.5.1</version>
        <executions>
          <execution>
            <phase>package</phase>
            <goals>
              <goal>shade</goal>
            </goals>
            <configuration>
              <promoteTransitiveDependencies>true</promoteTransitiveDependencies>
              <transformers>
                <transformer>
                  <mainClass>com.chatcyber.App</mainClass>
                </transformer>
              </transformers>
              <filters>
                <filter>
                  <artifact>*:*</artifact>
                  <excludes>
                    <exclude>META-INF/*.SF</exclude>
                    <exclude>META-INF/*.DSA</exclude>
                    <exclude>META-INF/*.RSA</exclude>
                  </excludes>
                </filter>
              </filters>
            </configuration>
          </execution>
        </executions>
      </plugin>
    </plugins>
  </build>
  <dependencies>
    <dependency>
      <groupId>com.sun.mail</groupId>
      <artifactId>javax.mail</artifactId>
      <version>1.6.2</version>
      <scope>system</scope>
      <systemPath>${project.basedir}/javax.mail-1.6.2.jar</systemPath>
    </dependency>
    <dependency>
      <groupId>javax.activation</groupId>
      <artifactId>activation</artifactId>
      <version>1.1.1</version>
      <scope>system</scope>
      <systemPath>${project.basedir}/activation.jar</systemPath>
    </dependency>
    <dependency>
      <groupId>it.unisa.dia.gas.jpbc</groupId>
      <artifactId>jpbc-api</artifactId>
      <version>2.0.0</version>
      <scope>system</scope>
      <systemPath>${project.basedir}/jpbc-api-2.0.0.jar</systemPath>
    </dependency>
    <dependency>
      <groupId>it.unisa.dia.gas.jpbc</groupId>
      <artifactId>jpbc-plaf</artifactId>
      <version>2.0.0</version>
      <scope>system</scope>
      <systemPath>${project.basedir}/jpbc-plaf-2.0.0.jar</systemPath>
    </dependency>
    <dependency>
      <groupId>it.unisa.dia.gas.jpbc</groupId>
      <artifactId>jpbc-crypto</artifactId>
      <version>2.0.0</version>
      <scope>system</scope>
      <systemPath>${project.basedir}/jpbc-crypto-2.0.0.jar</systemPath>
    </dependency>
    <dependency>
      <groupId>it.unisa.dia.gas.jpbc</groupId>
      <artifactId>jpbc-pbc</artifactId>
      <version>2.0.0</version>
      <scope>system</scope>
      <systemPath>${project.basedir}/jpbc-pbc-2.0.0.jar</systemPath>
    </dependency>
    <dependency>
      <groupId>it.unisa.dia.gas.jpbc</groupId>
      <artifactId>jpbc-mm</artifactId>
      <version>2.0.0</version>
      <scope>system</scope>
      <systemPath>${project.basedir}/jpbc-mm-2.0.0.jar</systemPath>
    </dependency>
    <dependency>
      <groupId>org.bouncycastle</groupId>
      <artifactId>bcprov-jdk16</artifactId>
      <version>1.46</version>
      <scope>system</scope>
      <systemPath>${project.basedir}/bcprov-jdk16-1.46.jar</systemPath>
    </dependency>
    <dependency>
      <groupId>net.java.dev.jna</groupId>
      <artifactId>jna</artifactId>
      <version>3.2.5</version>
      <scope>system</scope>
      <systemPath>${project.basedir}/jna-3.2.5.jar</systemPath>
    </dependency>
  </dependencies>
  <properties>
    <project.build.sourceEncoding>UTF-8</project.build.sourceEncoding>
    <maven.compiler.target>11</maven.compiler.target>
    <maven.compiler.source>11</maven.compiler.source>
  </properties>
</project>
